# Public-safe example. Copy to .env locally and fill with your own values.
# Keep simulation unless you intentionally enable live trading.
TRADING_MODE=simulation

# Live trading requires all three explicit local-only confirmations.
# Never commit a real .env file.
POLYFUN_ENABLE_LIVE_TRADING=false
POLYFUN_I_UNDERSTAND_LIVE_RISK=NO
POLYFUN_I_WILL_NOT_COMMIT_KEYS=NO

MODEL_PREDICTION_HOST=http://127.0.0.1
MODEL_PREDICTION_PORT=8080
RPC_URL=https://polygon-rpc.com
MONGO_URI=mongodb://localhost:27017/polymarket_trading

# Wallet / API values. Leave blank in simulation.
PROXY_WALLET=
PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Conservative defaults for local live testing if explicitly enabled.
ALLOWED_MARKETS=ETH
TIMEFRAME=15m
BET_SIZE_PERCENT=1
MAX_TRADES_PER_SESSION=1
RISK_CONTROL_ENABLED=true
LOGS_DIR=logs_local
HTTPS_PROXY=
