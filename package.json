{
  "name": "freqai-polymarket-trading",
  "version": "1.0.0",
  "description": "LightGBM-FreqAI 预测 + Polymarket 自动交易 TS 脚本",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node -e \"console.log('Polyfun sandbox: use npm run start:simulation for paper mode or npm run start:trading for opt-in live mode.');\"",
    "start:trading": "npm --prefix polymarket run predict-trade:live",
    "dev": "ts-node src/typescript/main.ts",
    "start:simulation": "npm --prefix polymarket run predict-trade"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.2.1",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.16.0",
    "mongodb": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
